# LLM Provider — choose: ollama | openai | claude
LLM_PROVIDER=ollama

# Ollama (default — runs locally)
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://ollama:11434   # set automatically in docker-compose

# OpenAI (optional)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Claude (optional — best report quality)
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Security — comma-separated allowlisted scan targets
ALLOWED_TARGETS=target,localhost,127.0.0.1
